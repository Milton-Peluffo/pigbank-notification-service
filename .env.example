# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# SQS Configuration
NOTIFICATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/pigbank-notification-email-sqs

# S3 Configuration
TEMPLATES_BUCKET_NAME=pigbank-templates-email-notification-123456789012

# DynamoDB Configuration
NOTIFICATION_TABLE_NAME=pigbank-notification-table
NOTIFICATION_ERROR_TABLE_NAME=pigbank-notification-error-table

# SMTP / Email Configuration
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-smtp-username-here
SMTP_PASSWORD=your-smtp-password-here
SMTP_FROM_EMAIL=noreply@pigbank.com

# Environment
NODE_ENV=development
