# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# DynamoDB
TABLE_NAME=pig-bank-notification-table
ERROR_TABLE_NAME=pig-bank-notification-error-table

# S3
S3_BUCKET_NAME=templates-email-notification

# SES
SES_FROM_EMAIL=noreply@pigbank.com

# SQS
NOTIFICATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account-id/notification-email-sqs
NOTIFICATION_ERROR_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account-id/notification-email-error-sqs

# Environment
NODE_ENV=production
LOG_LEVEL=info