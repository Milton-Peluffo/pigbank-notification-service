{
  "name": "pigbank-notification-service",
  "version": "1.0.0",
  "description": "Microservicio de notificaciones por email para PigBank",
  "main": "dist/handlers/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/handlers/send-notifications.handler.ts",
    "start": "node dist/handlers/send-notifications.handler.js",
    "deploy": "npm run build && cd infrastructure/terraform && terraform apply -auto-approve",
    "tf:init": "cd infrastructure/terraform && terraform init",
    "tf:plan": "cd infrastructure/terraform && terraform plan",
    "tf:apply": "cd infrastructure/terraform && terraform apply",
    "tf:destroy": "cd infrastructure/terraform && terraform destroy",
    "upload-templates": "node scripts/upload-templates.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "aws",
    "lambda",
    "sqs",
    "ses",
    "notifications",
    "email"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.445.0",
    "@aws-sdk/client-s3": "^3.445.0",
    "@aws-sdk/client-ses": "^3.445.0",
    "@aws-sdk/client-sqs": "^3.445.0",
    "@aws-sdk/lib-dynamodb": "^3.445.0",
    "aws-lambda": "^1.0.7",
    "class-validator": "^0.14.0",
    "handlebars": "^4.7.7",
    "node-cache": "^5.1.2",
    "pino": "^8.16.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.26",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "aws-sdk-client-mock": "^4.0.0",
    "esbuild": "^0.19.10",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "pino-pretty": "^10.2.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
